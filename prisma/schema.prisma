// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  trialEndsAt  DateTime
  active       Boolean        @default(true)
  branches     Branch[]
  users        User[]
  type         CompanyType    @default(RETAIL)
  createdAt    DateTime       @default(now())
  Category     Category[]
  Product      Product[]
  Client       Client[]
  Sale         Sale[]
  CashboxLog   CashboxLog[]
  MetricRecord MetricRecord[]
}

model Branch {
  id         String       @id @default(cuid())
  name       String
  company    Company      @relation(fields: [companyId], references: [id])
  companyId  String
  sales      Sale[]
  stockItems StockItem[]
  createdAt  DateTime     @default(now())
  CashboxLog CashboxLog[]
}

model User {
  id         String       @id @default(cuid())
  email      String       @unique
  password   String
  name       String
  role       Role
  company    Company      @relation(fields: [companyId], references: [id])
  companyId  String
  createdAt  DateTime     @default(now())
  Sale       Sale[]
  CashboxLog CashboxLog[]
}

enum Role {
  ADMIN
  CASHIER
}

model Category {
  id        String    @id @default(cuid())
  name      String
  company   Company   @relation(fields: [companyId], references: [id])
  companyId String
  products  Product[]
}

model Product {
  id         String       @id @default(cuid())
  name       String
  category   Category     @relation(fields: [categoryId], references: [id])
  categoryId String
  price      Float
  cost       Float        @default(0)
  stockItems StockItem[]
  company    Company      @relation(fields: [companyId], references: [id])
  companyId  String
  SaleDetail SaleDetail[]
}

model StockItem {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id])
  productId String
  branch    Branch  @relation(fields: [branchId], references: [id])
  branchId  String
  quantity  Int
}

model Client {
  id        String  @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   Company @relation(fields: [companyId], references: [id])
  companyId String
  sales     Sale[]
}

model Sale {
  id          String       @id @default(cuid())
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  branch      Branch       @relation(fields: [branchId], references: [id])
  branchId    String
  company     Company      @relation(fields: [companyId], references: [id])
  companyId   String
  client      Client?      @relation(fields: [clientId], references: [id])
  clientId    String?
  saleDetails SaleDetail[]
  total       Float
  createdAt   DateTime     @default(now())
}

model SaleDetail {
  id        String  @id @default(cuid())
  sale      Sale    @relation(fields: [saleId], references: [id])
  saleId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Float
}

model CashboxLog {
  id        String      @id @default(cuid())
  branch    Branch      @relation(fields: [branchId], references: [id])
  branchId  String
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  amount    Float
  type      CashboxType
  createdAt DateTime    @default(now())
  Company   Company?    @relation(fields: [companyId], references: [id])
  companyId String?
}

enum CompanyType {
  RETAIL
  WHOLESALE
}

enum CashboxType {
  OPENING
  CLOSURE
  MOVEMENT
}

model MetricRecord {
  id         String   @id @default(cuid())
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  period     DateTime // monthly or weekly aggregate
  income     Float
  expenses   Float
  projection Float // calculated
}
